## Step 1 — Scaffold the workflow

### 1A. Workflow struct

Create a struct embedding `BaseWorkflow` with compile-time interface check:

```go
package workflows

type <resource><operation>Workflow struct {
	BaseWorkflow
}

var _ WorkflowInterface = &<resource><operation>Workflow{}
```

### 1B. Entry point function

Follow the canonical lifecycle: **new → Setup → EnsureJobState → PROCESSING → Run → DONE/ERROR**:

```go
func <Resource><Operation>Workflow(ctx workflow.Context, params *common.<Resource><Operation>Params) error {
	wf := new(<resource><operation>Workflow)

	if err := wf.Setup(ctx, params); err != nil {
		return err
	}

	if err := wf.EnsureJobState(ctx, models.JobsStateNEW); err != nil {
		return err
	}

	wf.Status = WorkflowStatusRunning
	if err := wf.UpdateJobStatus(ctx, string(models.JobsStatePROCESSING), nil); err != nil {
		wf.Logger.Errorf("failed to update job status to PROCESSING: %v", err)
		return err
	}

	_, errRun := wf.Run(ctx, params)
	if errRun != nil {
		wf.Status = WorkflowStatusFailed
		if updateErr := wf.UpdateJobStatus(ctx, string(models.JobsStateERROR), errRun); updateErr != nil {
			wf.Logger.Errorf("failed to update job status to ERROR: %v", updateErr)
		}
		return errRun
	}

	wf.Status = WorkflowStatusCompleted
	if err := wf.UpdateJobStatus(ctx, string(models.JobsStateDONE), nil); err != nil {
		wf.Logger.Errorf("failed to update job status to DONE: %v", err)
		return err
	}
	return nil
}
```

### 1C. Setup method

```go
func (wf *<resource><operation>Workflow) Setup(ctx workflow.Context, input interface{}) error {
	params := input.(*common.<Resource><Operation>Params)
	info := workflow.GetInfo(ctx)
	wf.ID = info.WorkflowExecution.ID
	wf.CustomerID = params.AccountName
	wf.Status = WorkflowStatusCreated

	ctx = util.AddExtraLoggerFields(ctx, map[string]interface{}{
		"workflowID": wf.ID,
		"customerID": wf.CustomerID,
	})
	wf.Logger = util.GetLogger(ctx)

	return workflow.SetQueryHandler(ctx, "status", func() (*WorkflowStatus, error) {
		return &WorkflowStatus{
			ID:         wf.ID,
			Status:     wf.Status,
			CustomerID: wf.CustomerID,
		}, nil
	})
}
```

### 1D. Run method

Configure activity options with retry policy and execute activities:

```go
func (wf *<resource><operation>Workflow) Run(ctx workflow.Context, args ...interface{}) (interface{}, *vsaerrors.CustomError) {
	params := args[0].(*common.<Resource><Operation>Params)
	log := wf.Logger

	retryPolicy, err := PopulateRetryPolicyParams(false)
	if err != nil {
		return nil, vsaerrors.NewVCPError(vsaerrors.ErrWorkflowConfigurationError, err)
	}

	ao := workflow.ActivityOptions{
		StartToCloseTimeout: retryPolicy.StartToCloseTimeout,
		HeartbeatTimeout:    retryPolicy.HeartBeatTimeout,
		RetryPolicy: &temporal.RetryPolicy{
			InitialInterval:       retryPolicy.InitialInterval,
			BackoffCoefficient:    retryPolicy.BackoffCoefficient,
			MaximumInterval:       retryPolicy.MaximumInterval,
			MaximumAttempts:       int32(retryPolicy.MaximumAttempts),
			NonRetryableErrorTypes: []string{"PanicError", "NonRetryableErr"},
		},
	}
	ctx = workflow.WithActivityOptions(ctx, ao)

	// Execute activities in sequence
	var result ResultType
	if err := workflow.ExecuteActivity(ctx, activityStruct.MethodName, activityArgs...).Get(ctx, &result); err != nil {
		log.Errorf("activity failed: %v", err)
		return nil, vsaerrors.ExtractCustomError(err)
	}

	return result, nil
}
```

