# Copy to .env.local (gitignored) and fill in. run-local.sh auto-sources .env.local.
# Required only for the AI adjudication stage (agent -p is headless and needs the key;
# the interactive `agent login` keychain session is NOT used in print mode).
export CURSOR_API_KEY=your-cursor-api-key-here

# Optional: private registry tokens (see docs/PRIVATE_REGISTRIES.md)
# export GH_PACKAGES_TOKEN=...
