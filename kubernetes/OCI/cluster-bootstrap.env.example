# Copy to a private file (e.g. cluster-bootstrap.env), fill in values, then:
#   set -a && source ./cluster-bootstrap.env && set +a
#   ./bootstrap-fresh-cluster.sh
#
# Do not commit real credentials to Git.

# --- Namespaces (defaults match charts) ---
# TEMPORAL_NS=temporal
# VCP_NS=vcp

# --- OCIR docker-registry secret (both namespaces) ---
OCIR_DOCKER_SERVER=iad.ocir.io
OCIR_DOCKER_USERNAME='tenancy-namespace/oci-username@example.com'
OCIR_DOCKER_PASSWORD='your-oci-auth-token'

# --- Temporal Postgres secrets (key must be "password") ---
TEMPORAL_DB_PASSWORD='your-temporal-postgres-password'

# --- VCP shared DB secret (oci-proxy + vcp-worker) ---
VCP_DB_USER=postgres
VCP_DB_PASSWORD='your-vcp-postgres-password'
VCP_DB_ADMIN_USER=postgres
# VCP_DB_ADMIN_PASSWORD defaults to VCP_DB_PASSWORD if unset
# VCP_DB_SECRET_NAME=vcp-db-secret

# --- Optional: OCI API key secret for vlm-worker (only if NOT using OKE workload identity) ---
# VLM_CREATE_OCI_API_SECRET=1
# VLM_OCI_API_SECRET_NAME=vlm-oci-auth
# OCI_API_TENANCY=ocid1.tenancy.oc1...
# OCI_API_USER=ocid1.user.oc1...
# OCI_API_FINGERPRINT=aa:bb:...
# OCI_API_PRIVATE_KEY_FILE=/path/to/oci_api_key.pem
# OCI_API_PASSPHRASE=

# --- After secrets: run Helm (default on). Set to 0 to stop after secrets. ---
# RUN_HELM=1
# EXTRA_HELM_ARGS='--wait --timeout 20m'
